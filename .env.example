# Database
DATABASE_URL=postgresql://agents:agents_dev@localhost:5432/agents

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Encryption key for API keys stored in DB (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=change-me

# Default AI provider (optional - can be configured via UI)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Orchestrator
ORCHESTRATOR_POLL_INTERVAL=5
ORCHESTRATOR_MAX_CONCURRENT=50
ORCHESTRATOR_LOCK_TTL=300
