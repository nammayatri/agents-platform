# ── Stage 1: Build dependencies ──────────────────────────────────
FROM python:3.12-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
        git build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml ./
COPY src/ src/

# Install PyTorch CPU-only first (avoids pulling ~1.5 GB of CUDA libs)
RUN pip install --no-cache-dir \
        torch --index-url https://download.pytorch.org/whl/cpu

# Install the package with optional extras
RUN pip install --no-cache-dir ".[embeddings,treesitter-grammars]"

# Strip test dirs, caches, and NVIDIA stubs from installed packages
RUN find /usr/local/lib/python3.12/site-packages \
    \( -name "tests" -o -name "test" -o -name "__pycache__" \
       -o -name "*.pyc" -o -name "*.pyo" \) \
    -type d -exec rm -rf {} + 2>/dev/null; \
    rm -rf /usr/local/lib/python3.12/site-packages/nvidia \
           /usr/local/lib/python3.12/site-packages/torch/test \
    ; exit 0

# ── Stage 2: Slim runtime ───────────────────────────────────────
FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy installed packages from builder (build-essential stays behind)
COPY --from=builder /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy application source
COPY src/ src/
COPY pyproject.toml ./

EXPOSE 8000

CMD ["uvicorn", "agents.api.app:create_app", "--factory", "--host", "0.0.0.0", "--port", "8000"]
